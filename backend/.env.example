# Database
DATABASE_URL="postgresql://username:password@localhost:5432/school_management_db"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="2h"

# Server
PORT=5000
NODE_ENV="development"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=450000
RATE_LIMIT_MAX_REQUESTS=80

# Email Configuration (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="SchoolHub <noreply@schoolhub.com>"
CLIENT_URL="https://school-management-client-one.vercel.app"
